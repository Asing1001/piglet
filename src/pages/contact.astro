---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/ContactSection.astro";
import { SITE } from "@data/constants";

const pageTitle: string = `關於我們 | ${SITE.title}`;
const contactUrl = `${SITE.url}/contact`;
---

<!--Utilizing MainLayout for the outer layout of the page, and defining meta for SEO purposes-->
<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": contactUrl,
    "url": contactUrl,
    "name": `關於我們 | ${SITE.title}`,
    "description": "認識豬豬隊友 Scott & Wendy：從 2019 環遊世界，到一家四口的親子旅行、育兒日常、生活選物與團購分享。",
    "isPartOf": {
      "@type": "WebSite",
      "url": SITE.url,
      "name": SITE.title,
      "description": SITE.description,
    },
    "inLanguage": "zh-TW"
  }}
>
  <ContactSection />
</MainLayout>
