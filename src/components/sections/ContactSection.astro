---
import { Icon } from "astro-icon/components";

const socialLinks = [
  {
    label: "YouTube",
    href: "https://www.youtube.com/channel/UCmcfZ1mCHeJ3Bzpm0dy1sSA",
    icon: "mdi:youtube",
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/piggyteammates/",
    icon: "mdi:instagram",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/piggyteammates/",
    icon: "mdi:facebook",
  },
];

const milestones = [
  {
    year: "2019",
    title: "25 歲環遊世界一年",
    body: "Scott 和 Wendy 離開熟悉的日常，踏上一段長途旅行。那一年不只是看世界，也重新理解生活、時間和家的樣子。",
  },
  {
    year: "現在",
    title: "一家四口繼續出發",
    body: "成為爸媽後，旅程多了孩子的節奏：行李、睡眠、情緒、午餐時間，以及很多意想不到的小冒險。",
  },
  {
    year: "日常",
    title: "把實際經驗整理給你",
    body: "從親子旅行、育兒觀察，到生活選物與團購資訊，豬豬隊友分享的是實際用過、走過、踩過也喜歡過的內容。",
  },
];

const values = [
  {
    icon: "mdi:compass-outline",
    title: "先生活，才內容",
    body: "每一篇分享都先回到真實家庭場景：孩子的節奏、爸媽的體力、預算和出發當天可能發生的小變化。",
  },
  {
    icon: "mdi:check-decagram-outline",
    title: "用過才推薦",
    body: "不把團購當成列表堆滿，而是把自己會不會再買、朋友問會不會推薦，放在最前面。",
  },
  {
    icon: "mdi:heart-outline",
    title: "留下可參考的細節",
    body: "好不好用、適合誰、不適合誰，都比漂亮結論更重要。希望讀完的人能更容易做自己的決定。",
  },
];
---

<section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-16">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-yellow-600 dark:text-yellow-400">
        關於豬豬隊友
      </p>
      <h1 class="mt-3 text-balance text-3xl font-bold text-neutral-900 dark:text-neutral-100 md:text-5xl md:leading-tight">
        Scott & Wendy，從兩個人的世界旅行，到一家四口的日常冒險。
      </h1>
      <p class="mt-5 text-pretty text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        豬豬隊友記錄親子旅行、育兒生活、家庭選物與團購資訊。這裡整理的是我們真實用過、走過、討論過，也希望能留給更多家庭參考的內容。
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/group-buy"
          class="inline-flex items-center gap-x-2 rounded-full bg-yellow-400 px-5 py-3 text-sm font-semibold text-neutral-900 transition hover:bg-yellow-300 focus:outline-none focus-visible:ring focus-visible:ring-yellow-500"
        >
          <Icon name="mdi:shopping-outline" size={20} />
          最新團購
        </a>
        <a
          href="https://www.instagram.com/piggyteammates/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-x-2 rounded-full border border-neutral-300 px-5 py-3 text-sm font-semibold text-neutral-800 transition hover:bg-neutral-100 focus:outline-none focus-visible:ring focus-visible:ring-neutral-400 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-800"
        >
          <Icon name="mdi:instagram" size={20} />
          合作聯絡
        </a>
      </div>
    </div>

    <div class="border-l-4 border-yellow-400 pl-6">
      <p class="text-pretty text-2xl font-semibold leading-9 text-neutral-900 dark:text-neutral-100">
        「旅行不一定要等到一切完美才出發。帶著孩子，也可以用自己的速度慢慢看世界。」
      </p>
      <p class="mt-4 text-neutral-600 dark:text-neutral-400">
        從 2019 年環遊世界開始，豬豬隊友把旅程中的觀察帶回日常：怎麼安排親子節奏、怎麼挑選真的好用的東西、怎麼讓家庭生活多一點彈性。
      </p>
    </div>
  </div>
</section>

<section class="border-y border-neutral-200 bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-950">
  <div class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-8 md:grid-cols-3">
      {
        milestones.map((item) => (
          <article>
            <p class="text-sm font-bold text-yellow-600 dark:text-yellow-400">{item.year}</p>
            <h2 class="mt-2 text-xl font-bold text-neutral-900 dark:text-neutral-100">{item.title}</h2>
            <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
  <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-yellow-600 dark:text-yellow-400">
        我們怎麼分享
      </p>
      <h2 class="mt-3 text-balance text-2xl font-bold text-neutral-900 dark:text-neutral-100 md:text-4xl">
        不是把生活包裝得完美，而是把真的有幫助的經驗留下來。
      </h2>
      <p class="mt-5 text-pretty leading-8 text-neutral-700 dark:text-neutral-300">
        豬豬隊友的內容從自己的家庭開始：旅行時怎麼安排行程、育兒現場怎麼調整、選物是不是真的能被日常反覆使用。這些判斷，才是我們希望讀者和合作品牌認識的部分。
      </p>
    </div>

    <div class="grid gap-4">
      {
        values.map((item) => (
          <article class="grid gap-4 rounded-lg border border-neutral-200 p-5 sm:grid-cols-[auto_1fr] dark:border-neutral-800">
            <div class="inline-flex size-12 items-center justify-center rounded-full bg-yellow-100 text-yellow-700 dark:bg-yellow-950 dark:text-yellow-300">
              <Icon name={item.icon} size={26} />
            </div>
            <div>
              <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">{item.title}</h3>
              <p class="mt-2 leading-7 text-neutral-700 dark:text-neutral-300">{item.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="bg-yellow-50 dark:bg-neutral-900">
  <div class="mx-auto grid max-w-[85rem] gap-8 px-4 py-12 sm:px-6 lg:grid-cols-[0.9fr_1.1fr] lg:px-8 lg:py-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 md:text-3xl">
        合作與聯絡
      </h2>
      <p class="mt-4 leading-7 text-neutral-700 dark:text-neutral-300">
        有品牌合作、團購提案、親子旅行內容邀約，或想詢問網站上的資訊，歡迎透過社群與豬豬隊友聯絡。
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-x-2 rounded-lg border border-yellow-200 bg-white px-4 py-4 text-sm font-semibold text-neutral-900 transition hover:border-yellow-400 hover:bg-yellow-100 focus:outline-none focus-visible:ring focus-visible:ring-yellow-500 dark:border-neutral-700 dark:bg-neutral-950 dark:text-neutral-100 dark:hover:bg-neutral-800"
          >
            <Icon name={link.icon} size={24} />
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
